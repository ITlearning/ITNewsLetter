# Copy this file to ops/codex/local-dispatch.env and edit as needed.

# Prefer a venv/interpreter that already has requirements.txt installed.
NEWSLETTER_PYTHON_BIN="/Users/tabber/ITNewsLetter/.venv/bin/python3"

# Set to 1 if you also want to rebuild dist/ after each dispatch.
NEWSLETTER_BUILD_ARCHIVE="0"

# Set to 1 if you want the Mac Studio run to commit/push updated state files.
NEWSLETTER_GIT_PUSH_AFTER_RUN="1"
NEWSLETTER_GIT_REMOTE="origin"
NEWSLETTER_GIT_BRANCH="main"
NEWSLETTER_GIT_AUTHOR_NAME="ITNewsLetter Bot"
NEWSLETTER_GIT_AUTHOR_EMAIL="41898282+github-actions[bot]@users.noreply.github.com"
NEWSLETTER_GIT_COMMIT_MESSAGE="chore: update newsletter state"

DISCORD_WEBHOOK_URL=""
DISCORD_MENTION=""

MIN_NEW_ITEMS_PER_RUN="5"
MAX_NEW_ITEMS_PER_RUN="7"
MAX_ITEM_AGE_DAYS="3"
TECH_PRIORITY_QUOTA="3"
GEEKNEWS_MAX_PER_RUN="3"

# Codex summary settings for English title/short summary enrichment.
CODEX_SUMMARY_MODEL=""
CODEX_SUMMARY_TIMEOUT_SEC="120"
CODEX_SUMMARY_SANDBOX="read-only"
CODEX_SUMMARY_EXTRA_ARGS=""

# Optional: only used when NEWSLETTER_BUILD_ARCHIVE="1".
DETAIL_BANNER_AD_SLOT=""
DETAIL_BANNER_AD_CLIENT="ca-pub-3668470088067384"
